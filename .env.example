# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Base de datos ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres@localhost:5432/matebot_db

# ─── Autenticación ───────────────────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ─── Meta / WhatsApp ─────────────────────────────────────────────────────────
# Lo encontrás en: developers.facebook.com → tu app → WhatsApp → API Setup
META_APP_SECRET=
WEBHOOK_VERIFY_TOKEN=
META_ACCESS_TOKEN=

# ─── IA ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ─── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ─── URLs del frontend ───────────────────────────────────────────────────────
PANEL_URL=http://localhost:5173
LANDING_URL=http://localhost:5174