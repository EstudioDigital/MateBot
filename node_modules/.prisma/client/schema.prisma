// Prisma schema for Mate-bot — WhatsApp SaaS for SMBs

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  password    String
  name        String
  accountId   String?   @unique
  plan        String    @default("trial")
  trialEndsAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  account Account? @relation(fields: [accountId], references: [id])
}

model Account {
  id            String   @id @default(cuid())
  name          String
  phoneNumberId String   @unique
  waToken       String
  ownerPhone    String
  industry      String?
  tone          String   @default("friendly")
  plan          String   @default("starter")
  businessInfo  String?
  faq           String?
  catalog       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user         User?
  modules      Module[]
  rules        Rule[]
  clients      Client[]
  messages     Message[]
  appointments Appointment[]
  transactions Transaction[]
  products     Product[]
}

model Module {
  id        String  @id @default(cuid())
  accountId String
  type      String // appointments | finance | catalog | ai | campaigns | loyalty
  active    Boolean @default(true)
  config    Json?

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, type])
}

model Rule {
  id        String  @id @default(cuid())
  accountId String
  trigger   Json // { type: 'keyword'|'startsWith'|'exact'|'regex'|'always', value: string }
  response  Json // { type: 'text'|'interactive_buttons'|'interactive_list', ... }
  priority  Int     @default(10)
  active    Boolean @default(true)

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model Client {
  id          String    @id @default(cuid())
  accountId   String
  phone       String
  name        String?
  tags        String[]
  points      Int       @default(0)
  lastContact DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  account      Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  messages     Message[]
  appointments Appointment[]

  @@unique([accountId, phone])
}

model Message {
  id          String   @id @default(cuid())
  accountId   String
  clientId    String
  direction   String // in | out
  type        String // text | audio | image | interactive | template
  body        String?
  autoSent    Boolean  @default(false)
  waMessageId String?
  createdAt   DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([accountId, clientId, createdAt])
}

model Appointment {
  id           String   @id @default(cuid())
  accountId    String
  clientId     String
  datetime     DateTime
  service      String?
  notes        String?
  status       String   @default("confirmed") // confirmed | cancelled | completed
  reminderSent Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([accountId, datetime])
}

model Transaction {
  id        String   @id @default(cuid())
  accountId String
  type      String // income | expense
  amount    Float
  category  String   @default("general")
  note      String?
  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, type, createdAt])
}

model Product {
  id          String  @id @default(cuid())
  accountId   String
  name        String
  description String?
  price       Float
  unit        String?
  imageUrl    String?
  available   Boolean @default(true)
  order       Int     @default(0)

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
}
