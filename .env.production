# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# ─── Base de datos ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/matebot_db

# ─── Autenticación ───────────────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ─── Meta / WhatsApp ─────────────────────────────────────────────────────────
META_APP_SECRET=
WEBHOOK_VERIFY_TOKEN=
META_ACCESS_TOKEN=

# ─── IA ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ─── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://app.matebot.app,https://matebot.app

# ─── URLs del frontend ───────────────────────────────────────────────────────
PANEL_URL=https://app.matebot.app
LANDING_URL=https://matebot.app